\@writefile{lof}{\contentsline {figure}{\numberline {10.5}{\ignorespaces Box plot distributions of final tumor cell counts across all treatment scenarios (n=20 per group). The bimodal distributions reflect the stochastic nature of tumor-immune dynamics, where early random events determine whether tumors are eliminated or escape immune control.}}{62}{figure.caption.50}\protected@file@percent }
\newlabel{fig:empirical-tumor-boxplot}{{10.5}{62}{Box plot distributions of final tumor cell counts across all treatment scenarios (n=20 per group). The bimodal distributions reflect the stochastic nature of tumor-immune dynamics, where early random events determine whether tumors are eliminated or escape immune control}{figure.caption.50}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.6}{\ignorespaces Survival rates across all treatment scenarios stratified by biological sex. Female patients demonstrate consistently higher survival rates across most treatment conditions, with the ICI+TKI combination achieving the highest survival rate (65\%) observed in the study.}}{62}{figure.caption.51}\protected@file@percent }
\newlabel{fig:empirical-survival-rate}{{10.6}{62}{Survival rates across all treatment scenarios stratified by biological sex. Female patients demonstrate consistently higher survival rates across most treatment conditions, with the ICI+TKI combination achieving the highest survival rate (65\%) observed in the study}{figure.caption.51}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.7}{\ignorespaces Mean tumor growth curves across treatment scenarios with ±1 standard deviation confidence bands (n=20 per scenario). The temporal analysis reveals distinct treatment response kinetics and wide confidence intervals reflecting the high stochasticity of tumor-immune interactions.}}{63}{figure.caption.52}\protected@file@percent }
\newlabel{fig:empirical-growth-curves}{{10.7}{63}{Mean tumor growth curves across treatment scenarios with ±1 standard deviation confidence bands (n=20 per scenario). The temporal analysis reveals distinct treatment response kinetics and wide confidence intervals reflecting the high stochasticity of tumor-immune interactions}{figure.caption.52}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.8}{\ignorespaces Immune cell killing activity comparison across treatment scenarios. ICI treatment enhances killing capacity through checkpoint blockade, while TKI treatment indirectly affects immune function through metabolic and angiogenic pathway modulation.}}{63}{figure.caption.53}\protected@file@percent }
\newlabel{fig:empirical-kills}{{10.8}{63}{Immune cell killing activity comparison across treatment scenarios. ICI treatment enhances killing capacity through checkpoint blockade, while TKI treatment indirectly affects immune function through metabolic and angiogenic pathway modulation}{figure.caption.53}{}}
