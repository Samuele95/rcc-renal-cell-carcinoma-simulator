\@writefile{lof}{\contentsline {figure}{\numberline {10.7}{\ignorespaces Mean tumor growth curves across treatment scenarios with ±1 standard deviation confidence bands (n=20 per scenario). The temporal analysis reveals distinct treatment response kinetics: rapid early control in ICI scenarios, sustained growth suppression with TKI treatment, and the complex dynamics of combination therapy. The wide confidence intervals reflect the high stochasticity of tumor-immune interactions.}}{125}{figure.caption.56}\protected@file@percent }
\newlabel{fig:empirical-growth-curves}{{10.7}{125}{Mean tumor growth curves across treatment scenarios with ±1 standard deviation confidence bands (n=20 per scenario). The temporal analysis reveals distinct treatment response kinetics: rapid early control in ICI scenarios, sustained growth suppression with TKI treatment, and the complex dynamics of combination therapy. The wide confidence intervals reflect the high stochasticity of tumor-immune interactions}{figure.caption.56}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.8}{\ignorespaces Immune cell killing activity comparison across treatment scenarios. ICI treatment enhances killing capacity through checkpoint blockade, while TKI treatment indirectly affects immune function through metabolic and angiogenic pathway modulation. The combination therapy shows complex interactions between these mechanisms that vary by biological sex.}}{125}{figure.caption.57}\protected@file@percent }
\newlabel{fig:empirical-kills}{{10.8}{125}{Immune cell killing activity comparison across treatment scenarios. ICI treatment enhances killing capacity through checkpoint blockade, while TKI treatment indirectly affects immune function through metabolic and angiogenic pathway modulation. The combination therapy shows complex interactions between these mechanisms that vary by biological sex}{figure.caption.57}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.9}{\ignorespaces Population dynamics across all cell types during simulation runs. The figure illustrates the temporal evolution of tumor cells, immune effectors, and regulatory populations under different treatment scenarios. Notable features include immune cell recruitment peaks following treatment initiation and the emergence of treatment-resistant cell populations in extended simulations.}}{126}{figure.caption.58}\protected@file@percent }
\newlabel{fig:population_dynamics}{{10.9}{126}{Population dynamics across all cell types during simulation runs. The figure illustrates the temporal evolution of tumor cells, immune effectors, and regulatory populations under different treatment scenarios. Notable features include immune cell recruitment peaks following treatment initiation and the emergence of treatment-resistant cell populations in extended simulations}{figure.caption.58}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.10}{\ignorespaces Detailed tumor growth analysis showing progression patterns under different treatment modalities. The analysis reveals distinct growth kinetics: exponential growth in untreated controls, growth suppression plateaus under TKI therapy, and oscillatory patterns reflecting immune-mediated control under ICI treatment. Sex differences in growth trajectories become apparent particularly under hormonal influence.}}{126}{figure.caption.59}\protected@file@percent }
\newlabel{fig:tumor_growth}{{10.10}{126}{Detailed tumor growth analysis showing progression patterns under different treatment modalities. The analysis reveals distinct growth kinetics: exponential growth in untreated controls, growth suppression plateaus under TKI therapy, and oscillatory patterns reflecting immune-mediated control under ICI treatment. Sex differences in growth trajectories become apparent particularly under hormonal influence}{figure.caption.59}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.11}{\ignorespaces Distribution of immune cell killing events across spatial regions and time points. The heatmap visualization reveals heterogeneous killing activity with preferential targeting of tumor periphery regions where immune-tumor contact is maximized. Treatment modalities shift both the intensity and spatial patterns of immune cytotoxic activity.}}{127}{figure.caption.60}\protected@file@percent }
\newlabel{fig:kill_distribution}{{10.11}{127}{Distribution of immune cell killing events across spatial regions and time points. The heatmap visualization reveals heterogeneous killing activity with preferential targeting of tumor periphery regions where immune-tumor contact is maximized. Treatment modalities shift both the intensity and spatial patterns of immune cytotoxic activity}{figure.caption.60}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.12}{\ignorespaces Quantitative analysis of killing event frequencies across treatment scenarios. The bar chart comparison demonstrates that while total killing events may decrease under some treatments, the efficiency per killing event increases significantly. This suggests that treatments enhance the quality rather than just the quantity of immune responses.}}{127}{figure.caption.61}\protected@file@percent }
\newlabel{fig:kill_counts}{{10.12}{127}{Quantitative analysis of killing event frequencies across treatment scenarios. The bar chart comparison demonstrates that while total killing events may decrease under some treatments, the efficiency per killing event increases significantly. This suggests that treatments enhance the quality rather than just the quantity of immune responses}{figure.caption.61}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.13}{\ignorespaces Statistical summary of immune cell killing performance including mean killing rates, variance measures, and confidence intervals across treatment groups. The analysis provides robust quantitative evidence for treatment efficacy differences while accounting for the inherent stochasticity of immune-tumor interactions.}}{128}{figure.caption.62}\protected@file@percent }
\newlabel{fig:kill_statistics}{{10.13}{128}{Statistical summary of immune cell killing performance including mean killing rates, variance measures, and confidence intervals across treatment groups. The analysis provides robust quantitative evidence for treatment efficacy differences while accounting for the inherent stochasticity of immune-tumor interactions}{figure.caption.62}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.14}{\ignorespaces Sex-stratified analysis revealing distinct treatment response patterns between male and female simulation scenarios. The results demonstrate significant sex-dependent differences in treatment efficacy, particularly for combination therapies, supporting the importance of personalized medicine approaches that consider biological sex as a key variable.}}{128}{figure.caption.63}\protected@file@percent }
\newlabel{fig:sex_stratified_results}{{10.14}{128}{Sex-stratified analysis revealing distinct treatment response patterns between male and female simulation scenarios. The results demonstrate significant sex-dependent differences in treatment efficacy, particularly for combination therapies, supporting the importance of personalized medicine approaches that consider biological sex as a key variable}{figure.caption.63}{}}
