\@writefile{lof}{\contentsline {figure}{\numberline {10.5}{\ignorespaces Box plot distributions of final tumor cell counts across all treatment scenarios (n=20 per group). The bimodal distributions reflect the stochastic nature of tumor-immune dynamics, where early random events determine whether tumors are eliminated or escape immune control. Note the dramatic variance within groups and the shift toward lower tumor burdens with effective treatments.}}{101}{figure.caption.38}\protected@file@percent }
\newlabel{fig:empirical-tumor-boxplot}{{10.5}{101}{Box plot distributions of final tumor cell counts across all treatment scenarios (n=20 per group). The bimodal distributions reflect the stochastic nature of tumor-immune dynamics, where early random events determine whether tumors are eliminated or escape immune control. Note the dramatic variance within groups and the shift toward lower tumor burdens with effective treatments}{figure.caption.38}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.6}{\ignorespaces Survival rates across all treatment scenarios stratified by biological sex. Female patients demonstrate consistently higher survival rates across most treatment conditions, with the ICI+TKI combination achieving the highest survival rate (65\%) observed in the study. The data reveal complex sex-treatment interactions that would be missed by single-seed analysis.}}{101}{figure.caption.39}\protected@file@percent }
\newlabel{fig:empirical-survival-rate}{{10.6}{101}{Survival rates across all treatment scenarios stratified by biological sex. Female patients demonstrate consistently higher survival rates across most treatment conditions, with the ICI+TKI combination achieving the highest survival rate (65\%) observed in the study. The data reveal complex sex-treatment interactions that would be missed by single-seed analysis}{figure.caption.39}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.7}{\ignorespaces Mean tumor growth curves across treatment scenarios with ±1 standard deviation confidence bands (n=20 per scenario). The temporal analysis reveals distinct treatment response kinetics: rapid early control in ICI scenarios, sustained growth suppression with TKI treatment, and the complex dynamics of combination therapy. The wide confidence intervals reflect the high stochasticity of tumor-immune interactions.}}{102}{figure.caption.40}\protected@file@percent }
\newlabel{fig:empirical-growth-curves}{{10.7}{102}{Mean tumor growth curves across treatment scenarios with ±1 standard deviation confidence bands (n=20 per scenario). The temporal analysis reveals distinct treatment response kinetics: rapid early control in ICI scenarios, sustained growth suppression with TKI treatment, and the complex dynamics of combination therapy. The wide confidence intervals reflect the high stochasticity of tumor-immune interactions}{figure.caption.40}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {10.8.9}Clinical and Methodological Implications}{102}{subsection.10.8.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10.8}{\ignorespaces Immune cell killing activity comparison across treatment scenarios. ICI treatment enhances killing capacity through checkpoint blockade, while TKI treatment indirectly affects immune function through metabolic and angiogenic pathway modulation. The combination therapy shows complex interactions between these mechanisms that vary by biological sex.}}{103}{figure.caption.41}\protected@file@percent }
